# ============================================================================
# Canopy — environment example. Copy to `.env` and fill in.
# NOTE: AI / Resend secrets are NOT set here — they are entered in the Admin
#       portal and stored AES-256-GCM encrypted in the database (see CONFIG_*).
# ============================================================================

# --- App ---
APP_ENV=development                       # development | staging | production
APP_PORT=8080
APP_BASE_URL=http://localhost:5173        # used to build links inside emails
API_PUBLIC_URL=http://localhost:8080      # base the clients call
LOG_LEVEL=debug                           # debug | info | warn | error
LOG_FORMAT=text                           # text | json (use json in prod)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Postgres ---
DATABASE_URL=postgres://canopy:canopy@localhost:5432/canopy?sslmode=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=2

# --- JWT ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# --- Config encryption (encrypts AI/Resend/MinIO secrets stored in DB) ---
# MUST be a base64-encoded 32-byte key. Generate one with:
#   openssl rand -base64 32
CONFIG_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY

# --- Bootstrap system admin (seeded once on first migrate) ---
BOOTSTRAP_ADMIN_EMAIL=admin@canopy.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeThis!123

# --- MinIO (object storage; may be overridden by Admin config) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=canopyadmin
MINIO_SECRET_KEY=canopyadmin
MINIO_BUCKET=canopy
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000    # public base for presigned URLs

# --- Host port overrides (change if a port is already used locally) ---
POSTGRES_PORT=5432
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Rate limiting ---
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_AI_PER_MIN=20

# ----------------------------------------------------------------------------
# These secrets are entered in Admin Settings, NOT here:
#   - Gemini API key
#   - Resend API key
# ----------------------------------------------------------------------------

# --- Frontend (apps/web) build-time vars (Vite) ---
VITE_API_BASE_URL=http://localhost:8080/api/v1
