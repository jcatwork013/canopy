{
  "name": "canopy",
  "version": "0.1.0",
  "private": true,
  "description": "Canopy — AI plant identification, disease diagnosis, care reminders & community marketplace.",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:web": "pnpm --filter @canopy/web dev",
    "dev:mobile": "pnpm --filter @canopy/mobile start",
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @canopy/shared build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css}\"",
    "infra:up": "docker compose up -d postgres minio createbuckets",
    "infra:down": "docker compose down",
    "api:dev": "docker compose up api",
    "stack:up": "docker compose up -d"
  },
  "devDependencies": {
    "prettier": "^3.4.2"
  }
}
