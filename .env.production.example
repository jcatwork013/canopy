# ============================================================================
# Canopy PRODUCTION env — copy to .env.production and fill in.
# Host 62.146.239.31 runs a system nginx as the TLS edge; Canopy's web/api bind
# to localhost ports and nginx vhosts (deploy/nginx/) proxy the 3 domains.
# Gemini/Resend keys are entered in the Admin portal (NOT here).
# ============================================================================

APP_ENV=production
APP_VERSION=1.0.0

# --- Public URLs (used for email links + CORS) ---
APP_BASE_URL=https://canopy.9bricks.com
API_PUBLIC_URL=https://api-canopy.9bricks.com
# web + admin origins call the api subdomain → both must be allowed (CORS).
CORS_ALLOWED_ORIGINS=https://canopy.9bricks.com,https://admin-canopy.9bricks.com
LOG_LEVEL=info
LOG_FORMAT=json

# --- Localhost ports proxied by the system nginx ---
WEB_HOST_PORT=13300
API_HOST_PORT=18100
WEB_API_BASE_URL=https://api-canopy.9bricks.com/api/v1

# --- Postgres (internal to the compose network) ---
POSTGRES_USER=canopy
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=canopy

# --- JWT (openssl rand -hex 32) ---
JWT_ACCESS_SECRET=CHANGE_ME_access_secret
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# --- Config encryption (REQUIRED) — openssl rand -base64 32 (32 bytes) ---
CONFIG_ENCRYPTION_KEY=CHANGE_ME_base64_32_byte_key

# --- Bootstrap system admin (created once on first boot) ---
BOOTSTRAP_ADMIN_EMAIL=admin@9bricks.com
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# --- MinIO (internal; expose publicly only when uploads go live in Phase 3) ---
MINIO_ACCESS_KEY=CHANGE_ME_minio_access
MINIO_SECRET_KEY=CHANGE_ME_minio_secret
MINIO_BUCKET=canopy
MINIO_PUBLIC_URL=https://api-canopy.9bricks.com
